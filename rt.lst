   198 000000C9 31C9                         XOR  CX,CX
   199 000000CB BB1027                       MOV  BX,10000
   200 000000CE E81800                       CALL PLSUB
   201 000000D1 BBE803                       MOV  BX,1000
   202 000000D4 E81200                       CALL PLSUB
   203 000000D7 BB6400                       MOV  BX,100
   204 000000DA E80C00                       CALL PLSUB
