   189                                  PRINT_LEFT:
   190 000000BC 85C0                         TEST AX,AX
   191 000000BE 7909                         JNS  PL1
   192 000000C0 F7D8                         NEG  AX
   193 000000C2 50                           PUSH AX
   194 000000C3 B02D                         MOV  AL,'-'
   195 000000C5 E8ED00                       CALL putc
   196 000000C8 58                           POP  AX
