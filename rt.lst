   204 000000EB F7F3                         DIV  BX
   205 000000ED 52                           PUSH DX
   206 000000EE 85C0                         TEST AX,AX
   207 000000F0 7408                         JZ   PS1
   208 000000F2 0430                         ADD  AL,'0'
   209 000000F4 E8BE00                       CALL putc
