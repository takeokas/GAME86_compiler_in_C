   348                                  ;;; ;;;;;;;;;
   349                                  ; takep8088
   350                                  USARTD  equ     00h     ;8251 data register
   351                                  USARTC  equ     01h     ;8251 control register
   352                                  ;
   353                                  %ifdef DOS
   354                                  ;--------------------------
   355                                  ; DOS I/O
   356                                  ;--------------------------
   357                                  putc:
   358 000001B5 50                           push ax
   359 000001B6 53                           push bx
   360 000001B7 51                           push cx
   361 000001B8 52                           push dx
   362                                       ;MOV  AH,02H
   363 000001B9 B406                         MOV  AH,06H
   364 000001BB 88C2                         MOV  DL,AL
   365 000001BD CD21                         INT  21H
   366 000001BF 5A                           pop dx
   367 000001C0 59                           pop cx
   368 000001C1 5B                           pop bx
   369 000001C2 58                           pop ax
   370 000001C3 C3                           RET
   371                                  getc:   
   372 000001C4 53                           push bx
   373 000001C5 51                           push cx
   374 000001C6 52                           push dx
   375                                       ;MOV  AH,08H
   376                                  getc1:
   377 000001C7 B406                         MOV  AH,06H
   378 000001C9 B2FF                         MOV  DL,0ffh
   379 000001CB CD21                         INT  21H
   380 000001CD 74F8                         jz getc1
   381 000001CF 30E4                         XOR  AH,AH
   382                                       ;call putc
   383 000001D1 5A                           pop dx
   384 000001D2 59                           pop cx
   385 000001D3 5B                           pop bx
   386 000001D4 C3                           RET
   387                                  %endif
   388                                  %ifdef RAW	
   389                                  ;--------------------------
   390                                  ; Serial I/O
   391                                  ;--------------------------
   392                                  putc:   push ax
   393                                  putc1:  in      al,USARTC       ;Get status
   394                                          and     al,01h          ;check TxBUF empty
   395                                          jz      putc1           ;wait for empty
   396                                          pop     ax              ;Restore char
   397                                          out     USARTD,al       ;Out it
   398                                          ret
   399                                          ;; end of putc
   400                                  
   401                                  getc:   
   402                                  getc1:
   403                                          ;;; himatubusi SW->LED
   404                                          in al,04h               ;read SW1
   405                                          add al,al
   406                                          add al,al
   407                                          out 0Ch,al              ;out LED
   408                                          ;;; 
   409                                          in      al,USARTC       ;Get status
   410                                          and     al,02h          ;check RxBUF full
   411                                          jz      getc1           ;wait for empty
   412                                          in      al,USARTD       ;Get Char
   413                                          ret
   414                                          ;; end of getc
   415                                  %endif
