   190 000000C9 31C9                         XOR  CX,CX
   191 000000CB BB1027                       MOV  BX,10000
   192 000000CE E81800                       CALL PLSUB
   193 000000D1 BBE803                       MOV  BX,1000
   194 000000D4 E81200                       CALL PLSUB
