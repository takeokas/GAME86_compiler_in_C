   212 000000EB F7F3                         DIV  BX
   213 000000ED 52                           PUSH DX
   214 000000EE 85C0                         TEST AX,AX
   215 000000F0 7408                         JZ   PS1
   216 000000F2 0430                         ADD  AL,'0'
   217 000000F4 E8BE00                       CALL putc
   218 000000F7 41                           INC  CX
