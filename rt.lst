   340                                  ;;; ;;;;;;;;;
   341                                  ; takep8088
   342                                  USARTD  equ     00h     ;8251 data register
   343                                  USARTC  equ     01h     ;8251 control register
   344                                  ;
   345                                  ;--------------------------
   346                                  ; Serial I/O
   347                                  ;--------------------------
   348 000001B5 50                      putc:   push ax
   349 000001B6 E401                    putc1:  in      al,USARTC       ;Get status
   350 000001B8 2401                            and     al,01h          ;check TxBUF empty
   351 000001BA 74FA                            jz      putc1           ;wait for empty
   352 000001BC 58                              pop     ax              ;Restore char
   353 000001BD E600                            out     USARTD,al       ;Out it
   354 000001BF C3                              ret
   355                                          ;; end of putc
   356                                  
   357                                  getc:   
   358                                  getc1:
   359                                          ;;; himatubusi SW->LED
   360 000001C0 E404                            in al,04h               ;read SW1
   361 000001C2 00C0                            add al,al
   362 000001C4 00C0                            add al,al
   363 000001C6 E60C                            out 0Ch,al              ;out LED
   364                                          ;;; 
   365 000001C8 E401                            in      al,USARTC       ;Get status
   366 000001CA 2402                            and     al,02h          ;check RxBUF full
   367 000001CC 74F2                            jz      getc1           ;wait for empty
   368 000001CE E400                            in      al,USARTD       ;Get Char
   369 000001D0 C3                              ret
   370                                          ;; end of getc
